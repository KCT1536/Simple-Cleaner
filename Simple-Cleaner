@echo off
:begin
echo Seclet a language(Type "lang" to show the list of supported language)
set /p command=
if "%command%"=="lang" goto ll
if "%command%"=="enus" goto enus
if "%command%"=="zhcn" goto zhcn
echo Invaild Code(Type "lang" to show the list of supported language)
goto begin
:ll
echo		Language--------Code
echo		English(US)-----enus
echo		简体中文--------zhcn
goto begin
:zhcn
echo    欢迎使用清理软件
echo    请注意！！！以下操作不可逆，请谨慎选择
echo    请注意！！！以下操作不可逆，请谨慎选择
echo    请注意！！！以下操作不可逆，请谨慎选择
echo    1.清理缓存软件(默认为*.tmp文件)
echo    2.清理无用Log文件
echo    3.清理希沃视频展台缓存(EasiCameraPhoto)
echo    4.自动清理(将会运行123)
echo    5.下载更新(输入htu来了解更新是如何进行的)
echo    6.打开系统自带清理软件(Cleanmgr.exe)
echo    7.更换语言
set /p o=
if "%o%"=="1" goto tmp
if "%o%"=="2" goto log
if "%o%"=="3" goto png
if "%o%"=="4" goto all
if "%o%"=="5" goto upd
if "%o%"=="6" goto clm
if "%o%"=="htu" goto htu
if "%o%"=="7" goto cl
echo 未知的服务，请重新输入
pause
goto zhcn
:tmp 
@echo off
cd C:\
echo 正在清理...
del %temp% /f /q
del *.tmp /f /q /s 
echo 清理完成!
goto zhcn
:log
cd C:\
echo 正在清理...(请耐心等待)
del *.log /f /q /s
echo 清理完成!
goto zhcn
:png
@echo off
echo 请输入希沃视频展台缓存(EasiCameraPhoto)所在的磁盘盘符(如C:)
set /p dp=
echo 正在清理...(请耐心等待)
rd /q /s %dp%\EasiCameraPhoto\
echo 清理完成!
goto zhcn
:all
echo 请输入希沃视频展台缓存(EasiCameraPhoto)所在的磁盘盘符(如C:)
set /p dpp=
echo 正在清理...(请耐心等待)
rd /q /s %dpp%\EasiCameraPhoto\
cd C:\
del *.log /f /q /s
del %temp% /f /q
del *.tmp /f /q /s
echo 清理完成!
goto zhcn
:upd
@echo off
echo 下载更新请注意日期，尽量选择最新的
start https://github.com/KCT1536/Simple-Cleaner/releases
echo 请将下载好的更新文件拖动到此处
set /p ud=
move %ud% "Cleaner.bat"
goto zhcn
:clm
cleanmgr
goto zhcn
:htu
echo 将下载好的文件拖入到提示符后，程序将会删除原有的版本后将下载好的文件移动到原先版本所在的目录
goto zhcn
:enus
echo    Welcome to use the Cleaning Software
echo    Be careful!!!The action can't be recovered.Choose wisely
echo    Be careful!!!The action can't be recovered.Choose wisely
echo    Be careful!!!The action can't be recovered.Choose wisely
echo    1.Clean the Cache(*.tmp)
echo    2.Clean the useless log file
echo    3.Auto Clean(Will run 123)
echo    4.Install Update(Type "htu" to know the program how to update)
echo    5.Open the clean software in system(Cleanmgr.exe)
echo    6.Change language
set /p p=
if "%p%"=="1" goto tmp2
if "%p%"=="2" goto log2
if "%p%"=="3" goto all2
if "%p%"=="4" goto upd2
if "%p%"=="5" goto clm2
if "%p%"=="htu" goto htu2
if "%p%"=="6" goto begin
echo Unknonw service,Try other service
pause
goto enus
